# Lark (Feishu) App Credentials — required
LARK_APP_ID=
LARK_APP_SECRET=

# Session data directory (default: ./data)
# SESSION_DATA_DIR=

# Daemon settings
# CLI_ID=claude-code              # CLI adapter: claude-code, aiden, coco, codex
# WORKING_DIR=~                   # Default working directory (comma-separated for multiple dirs, e.g. ~/projects,~/work)

# Access control (comma-separated emails or Lark open_ids, empty = allow all)
# ALLOWED_USERS=alice@example.com,ou_xxxx

# Project scanning directory for /repo command (default: parent of WORKING_DIR)
# PROJECT_SCAN_DIR=

# Web terminal settings
# WEB_HOST=0.0.0.0                # HTTP server bind address
# WEB_EXTERNAL_HOST=               # External hostname/IP for terminal URLs (default: auto-detect LAN IP)

# Multi-bot: path to bots.json config file (see bots.json.example)
# When set, LARK_APP_ID/LARK_APP_SECRET/CLI_ID are ignored — use bots.json instead
# Default search: ~/.botmux/bots.json
# BOTS_CONFIG=

# Debug logging
# DEBUG=1
