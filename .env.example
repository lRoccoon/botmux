# Lark (Feishu) App Credentials — required
LARK_APP_ID=
LARK_APP_SECRET=
LARK_DEFAULT_CHAT_ID=

# Session data directory (default: ./data)
# SESSION_DATA_DIR=

# Daemon settings
# LARK_BRIDGE_MODEL=opus          # Claude model: opus, sonnet, haiku
# LARK_BRIDGE_MAX_TURNS=500       # Max conversation turns per session
# CLAUDE_PATH=claude              # Path to Claude CLI binary
# CLAUDE_WORKING_DIR=~            # Default working directory for Claude

# Access control (comma-separated Lark open_ids, empty = allow all)
# ALLOWED_USERS=

# Project scanning directory for /repo command (default: parent of CLAUDE_WORKING_DIR)
# PROJECT_SCAN_DIR=

# Web terminal settings
# WEB_HOST=0.0.0.0                # HTTP server bind address
# WEB_EXTERNAL_HOST=               # External hostname/IP for terminal URLs (default: auto-detect LAN IP)

# Debug logging
# DEBUG=1
